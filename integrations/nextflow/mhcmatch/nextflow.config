// Per-process config for the MHCMATCH_PREDICT module. `includeConfig` this from your pipeline's
// config (e.g. workflows/neoantigens/nextflow.config), mirroring how the other predictor modules are
// wired. Species follows `params.genome` -- the iGenomes assembly key nf-core sets from `--genome` --
// so mhcmatch follows the assembly the rest of the pipeline already runs on, exactly as the ARDA
// module does, with no extra parameter to configure:
//   GRCm39 -> --species mouse      anything else (GRCh38, ...) -> --species human
process {
    withName: 'MHCMATCH_PREDICT' {
        // Map the assembly to mhcmatch's --species. Append any extra `mhcmatch predict` flags here too.
        ext.args = { params.genome == 'GRCm39' ? '--species mouse' : '--species human' }
        publishDir = [
            path: { "${params.outdir}/mhcmatch" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

// Reference tier and %rank binder cutoff (defaults shown). Override in your pipeline's params.
params.mhcmatch_tier            = 'full'
params.mhcmatch_rank_threshold  = 2.0
